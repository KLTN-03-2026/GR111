# ================================================================
# Root .env — Dùng cho docker-compose
# Sao chép: cp .env.example .env
# ================================================================

# --- PostgreSQL (Docker) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# --- JWT ---
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d
BOOKING_CANCEL_SUPPORT_TOKEN_EXPIRES_IN=14d

# --- External APIs ---
GEMINI_API_KEY=
STRIPE_SECRET_KEY=